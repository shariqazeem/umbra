{
  "name": "umbra",
  "version": "0.1.0",
  "private": true,
  "description": "Umbra — a consumer privacy layer for Stellar commerce. One-click shielding, private transfers, private invoices, and private donation links.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "benchmark": "tsx packages/benchmarks/bin/benchmark.ts",
    "benchmark:list": "tsx packages/benchmarks/bin/benchmark.ts --list",
    "benchmark:json": "tsx packages/benchmarks/bin/benchmark.ts --format=json",
    "bench:typecheck": "pnpm --filter \"./packages/*\" run typecheck",
    "bench:gen-constants": "tsx packages/crypto-bls/scripts/gen-constants.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "2.4.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@stellar/freighter-api": "6.0.1",
    "@stellar/stellar-sdk": "16.0.1",
    "@umbra/crypto-bls": "workspace:*",
    "@umbra/wallet-core": "workspace:*",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "12.40.0",
    "lenis": "1.3.23",
    "lucide-react": "^0.454.0",
    "next": "15.5.19",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "snarkjs": "0.7.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.19",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
