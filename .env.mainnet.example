# =============================================================================
# Umbra — MAINNET canary env template.
#
# Copy the values you need into .env.local (local) AND your Vercel project env
# (production). These NEXT_PUBLIC_* vars are inlined at build time, so a change
# means a rebuild/redeploy of the site.
#
# HONEST STATUS: this arms an EXPERIMENTAL, CAPPED, INVITE-ONLY canary on Stellar
# mainnet. It is self-reviewed, NOT independently audited, and uses a single-
# contributor trusted setup. The UI labels it as such everywhere. Keep the cap
# small and only expose funds you can afford to lose.
# =============================================================================

# ── Network ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_UMBRA_NETWORK=mainnet
NEXT_PUBLIC_UMBRA_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
# Public, no-signup mainnet Soroban RPC. sorobanrpc.com proved most reliable for submission
# (Gateway timed out); all allow browser CORS. Fallbacks: gateway.fm · rpc.lightsail.network.
NEXT_PUBLIC_UMBRA_RPC_URL=https://mainnet.sorobanrpc.com
# Optional: inclusion (bid) fee in stroops. Defaults to 1000000 (0.1 XLM) on mainnet to beat
# surge pricing; the app auto-detects mainnet, so you usually don't need to set this.
# NEXT_PUBLIC_UMBRA_INCLUSION_FEE=1000000
# Filled in AFTER deploy-mainnet.sh writes infra/deploy/deployment.mainnet.json
NEXT_PUBLIC_UMBRA_POOL_CONTRACT=

# ── Capped canary (money paths) ──────────────────────────────────────────────
NEXT_PUBLIC_UMBRA_ENABLE_CANARY=true
# Hard per-deposit cap in XLM (client-side). 0 disables deposits.
NEXT_PUBLIC_UMBRA_MAX_DEPOSIT_XLM=100

# ── Access gate ──────────────────────────────────────────────────────────────
# false = open/public (best for a demo). true = invite-only (needs INVITE_HASHES below).
NEXT_PUBLIC_UMBRA_INVITE_REQUIRED=false
# Comma-separated SHA-256 (hex) of each issued code, UPPER-CASE normalized.
# Regenerate with:  printf '%s' "UMBRA-XXXX-XXXX" | shasum -a 256
NEXT_PUBLIC_UMBRA_INVITE_HASHES=<hash1>,<hash2>,<hash3>
# Optional: powers the "Request an invite" mailto on the gate.
NEXT_PUBLIC_UMBRA_CONTACT_EMAIL=you@example.com
