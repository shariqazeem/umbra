# Umbra benchmark — testnet configuration (copy to repo-root .env and fill in).
# Enables B04 (on-chain verification), B05 (instruction budget), B06 (resources).

# Soroban RPC endpoint.
UMBRA_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase. Testnet:
UMBRA_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# A funded testnet source account secret key (S...). Fund via friendbot:
#   https://friendbot.stellar.org/?addr=<G...>
UMBRA_SOURCE_SECRET=S...

# Optional: reuse an already-deployed verifier instead of redeploying each run.
# UMBRA_VERIFIER_CONTRACT=C...

# Optional: which exported circuit to verify on-chain (default bench_hash).
UMBRA_SOROBAN_ARTIFACT=bench_hash

# -----------------------------------------------------------------------------
# deploy-slice.sh / capture-demo-txs.sh — testnet slice deploy.
# These have sane defaults and need NO .env to run once the identity exists; set
# them only to override. They do NOT use UMBRA_SOURCE_SECRET (above) — the deploy
# uses a named stellar identity instead.
# -----------------------------------------------------------------------------

# Network (deploy is testnet-only; mainnet is intentionally blocked). Default: testnet.
# UMBRA_NETWORK=testnet

# Single deployer-identity config var: a named `stellar keys` identity.
# Create + fund it once with:  stellar keys generate umbra-deployer --network testnet --fund
# (G7: this var becomes the multi-sig signer alias — not implemented yet.)
# UMBRA_DEPLOYER=umbra-deployer

# Optional overrides (defaults shown):
# UMBRA_HORIZON_URL=https://horizon-testnet.stellar.org
# UMBRA_EXPLORER_BASE=https://stellar.expert/explorer/testnet
