# Umbra — environment. Copy to .env.local. ALL values here are PUBLIC (no secrets).
# Without these the app still does all local crypto + in-browser proving; only on-chain
# submission (shield/withdraw) needs a configured pool.

# A deployed UmbraPool contract on Stellar testnet — the pool the app shields into and
# withdraws from. Deploy one with infra/deploy/deploy-slice.sh, or use an existing id.
NEXT_PUBLIC_UMBRA_POOL_CONTRACT=

# Soroban RPC + network. Defaults below are testnet; leave as-is for the hackathon.
NEXT_PUBLIC_UMBRA_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_UMBRA_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Proving mode: "live" = real in-browser Groth16 proving (default).
# "pregen" replays a pre-generated demo proof (only if a demo proof file is present).
NEXT_PUBLIC_UMBRA_PROOF_MODE=live
